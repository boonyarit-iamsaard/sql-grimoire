{
  "name": "sql-grimoire",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "audit": "pnpm audit --audit-level moderate && pnpm audit signatures",
    "build": "turbo run build",
    "check": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "ci": "biome ci --no-errors-on-unmatched --files-ignore-unknown=true . && pnpm types:check && pnpm test && pnpm build",
    "dev": "turbo run dev",
    "md:check": "prettier --write \"**/*.md\" && markdownlint \"**/*.md\" --ignore-path .gitignore",
    "prepare": "husky || true",
    "sql:check": "sqlfluff fix apps && sqlfluff lint apps",
    "test": "turbo run test",
    "types:check": "turbo run types:check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli": "^0.49.1",
    "prettier": "^3.9.5",
    "turbo": "^2.10.4",
    "wrangler": "^4.110.0"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "*.md": [
      "prettier --check",
      "markdownlint --ignore-path .gitignore"
    ],
    "*.sql": [
      "sqlfluff lint"
    ]
  },
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.11.0 <12"
  },
  "packageManager": "pnpm@11.11.0"
}
